   <Filename>org.kde.qrca.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Utilities</Name>
  <Exclude>
   <Filename>org.kde.kwrite.desktop</Filename>
   <Filename>vim.desktop</Filename>
  </Exclude>
